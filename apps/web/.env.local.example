# Rename this file to .env.local and fill in your secrets.

# Deepgram transcription (required) — pre-recorded upload API with speaker diarization.
# Get your key at: https://console.deepgram.com/
DEEPGRAM_API_KEY="your-deepgram-key"
DEEPGRAM_MODEL="nova-3"
DEEPGRAM_LANGUAGE="en"
# Optional overrides:
# DEEPGRAM_URL="https://api.deepgram.com/v1/listen"
# DEEPGRAM_TIMEOUT_MS="30000"
# DEEPGRAM_MAX_RETRIES="2"

# Anthropic API key for clinical note generation (required)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-your-key"

# Base64-encoded 32-byte secret used for client-side secure storage.
# Generate with: openssl rand -base64 32
NEXT_PUBLIC_SECURE_STORAGE_KEY="base64-secret"

# Shared-password gate for hosted demos (optional).
# When set, the whole site is locked behind a password (see /login).
# Leave unset for local development to keep the app open.
DEMO_PASSWORD=""
# Optional second password granting the bring-your-own-key (BYOK) role:
# those sessions must supply their own Deepgram/Anthropic keys in Settings
# (the server refuses to spend the env keys on them) and archive to
# BOX_FOLDER_ID_BYOK. Only active when DEMO_PASSWORD is also set.
DEMO_PASSWORD_BYOK=""

# --- Consultation archival to Box (optional) ---
# When enabled, each completed consultation is archived as a self-contained
# container — audio.wav + transcript.txt + raw_transcript.json + note_v<N>.md +
# metadata.json — in a Box folder. Leave archival unconfigured to disable
# entirely; the app works exactly the same without it.
BOX_ENABLED="false"
# Destination folder ID — the number in its Box URL (.../folder/<id>).
BOX_FOLDER_ID=""
# Optional separate destination for BYOK-role sessions (falls back to
# BOX_FOLDER_ID when unset).
BOX_FOLDER_ID_BYOK=""
# Auth option A — Server Authentication with JWT (used in production).
# Base64 of the keypair config JSON from the Box dev console (app →
# Configuration → Add and Manage Public Keys → "Generate a Public/Private
# Keypair"). scripts/box-upload-test.mjs verifies a keypair and prints this line.
BOX_JWT_CONFIG=""
# Auth option B — Client Credentials Grant (only for CCG-auth Box apps).
BOX_CLIENT_ID=""
BOX_CLIENT_SECRET=""
BOX_SUBJECT_ID=""              # Enterprise ID (or a user ID, with BOX_SUBJECT_TYPE=user)
BOX_SUBJECT_TYPE="enterprise"  # "enterprise" (App User) or "user"
# Auth option C — a short-lived developer token, for quick local testing only
# (expires ~60 min). Takes precedence over JWT and CCG when set.
BOX_DEVELOPER_TOKEN=""
