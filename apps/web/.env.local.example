# Rename this file to .env.local and fill in your secrets.

# Deepgram transcription (required) — pre-recorded upload API with speaker diarization.
# Get your key at: https://console.deepgram.com/
DEEPGRAM_API_KEY="your-deepgram-key"
DEEPGRAM_MODEL="nova-3"
DEEPGRAM_LANGUAGE="en"
# Optional overrides:
# DEEPGRAM_URL="https://api.deepgram.com/v1/listen"
# DEEPGRAM_TIMEOUT_MS="30000"
# DEEPGRAM_MAX_RETRIES="2"

# Anthropic API key for clinical note generation (required)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-your-key"

# Base64-encoded 32-byte secret used for client-side secure storage.
# Generate with: openssl rand -base64 32
NEXT_PUBLIC_SECURE_STORAGE_KEY="base64-secret"

# Shared-password gate for hosted demos (optional).
# When set, the whole site is locked behind a single password (see /login).
# Leave unset for local development to keep the app open.
DEMO_PASSWORD=""

# --- Consultation archival (optional) ---
# When enabled, each completed consultation is archived as a self-contained
# container — audio.wav + transcript.txt + raw_transcript.json + note.md +
# metadata.json — to the backend selected by STORAGE_BACKEND. Leave archival
# unconfigured to disable entirely; the app works exactly the same without it.
#
# STORAGE_BACKEND selects the backend: "r2" (Cloudflare R2) or "box".
# Defaults to "box" when unset, so existing Box deployments are unchanged.
STORAGE_BACKEND="r2"

# --- Cloudflare R2 (used when STORAGE_BACKEND=r2) ---
# S3-compatible object storage. Create a bucket + an Account API token with
# "Object Read & Write" scoped to that bucket; the token screen shows the
# access key pair and the S3 endpoint (https://<account>.r2.cloudflarestorage.com).
R2_ACCOUNT_ID=""          # the <account> in the S3 endpoint hostname
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="discascribe-consultations"

# --- Box archival (used when STORAGE_BACKEND=box) ---
BOX_ENABLED="false"
# Destination "Working folder" ID — the number in its Box URL (.../folder/<id>).
BOX_FOLDER_ID=""
# Auth option A — Client Credentials Grant (a service account). Recommended for
# production; acts as the App User when the subject is the enterprise.
BOX_CLIENT_ID=""
BOX_CLIENT_SECRET=""
BOX_SUBJECT_ID=""              # Enterprise ID (or a user ID, with BOX_SUBJECT_TYPE=user)
BOX_SUBJECT_TYPE="enterprise"  # "enterprise" (App User) or "user"
# Auth option B — a short-lived developer token, for quick local testing only
# (expires ~60 min). Takes precedence over CCG when set.
BOX_DEVELOPER_TOKEN=""
