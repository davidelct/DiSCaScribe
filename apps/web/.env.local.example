# Rename this file to .env.local and fill in your secrets.

# OpenAI API key for audio transcription (required)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-your-key"

# Transcription provider:
# - deepgram (Deepgram pre-recorded upload API, with speaker diarization)
# - whisper_local (default, local tiny Whisper server)
# - whisper_openai (OpenAI hosted Whisper API)
# - medasr (legacy local MedASR server)
TRANSCRIPTION_PROVIDER="whisper_local"

# Deepgram config (used when TRANSCRIPTION_PROVIDER=deepgram)
# Get your key at: https://console.deepgram.com/
DEEPGRAM_API_KEY="your-deepgram-key"
DEEPGRAM_MODEL="nova-3"
DEEPGRAM_LANGUAGE="en"
# Optional overrides:
# DEEPGRAM_URL="https://api.deepgram.com/v1/listen"
# DEEPGRAM_TIMEOUT_MS="30000"
# DEEPGRAM_MAX_RETRIES="2"

# Language Configuration (optional):
# - auto (same as variable unset, used for automatic language detection if used with multilingual model and English if used with .en model)
# - any language code by ISO-639-1 standards (e.g. 'en', 'es', 'fr'), ignored if language not supported my model.
# See GitHub for all supported languages: https://github.com/openai/whisper#available-models-and-languages
WHISPER_LANGUAGE="auto"

# Local Whisper server config (used when TRANSCRIPTION_PROVIDER=whisper_local)
WHISPER_LOCAL_URL="http://127.0.0.1:8002/v1/audio/transcriptions"
WHISPER_LOCAL_MODEL="tiny.en"
WHISPER_LOCAL_BACKEND="cpp"
WHISPER_LOCAL_GPU="1"
WHISPER_LOCAL_TIMEOUT_MS="15000"
WHISPER_LOCAL_MAX_RETRIES="2"

# OpenAI Whisper config (used when TRANSCRIPTION_PROVIDER=whisper_openai)
WHISPER_OPENAI_MODEL="whisper-1"

# Anthropic API key for clinical note generation (required)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-your-key"

# Base64-encoded 32-byte secret used for client-side secure storage.
# Generate with: openssl rand -base64 32
NEXT_PUBLIC_SECURE_STORAGE_KEY="base64-secret"

# Shared-password gate for hosted demos (optional).
# When set, the whole site is locked behind a single password (see /login).
# Leave unset for local development to keep the app open.
DEMO_PASSWORD=""

# --- Box archival (optional) ---
# When enabled, each completed consultation is archived to a Box folder as a
# self-contained subfolder: audio.wav + transcript.txt + raw_transcript.json +
# note.md + metadata.json. Leave BOX_ENABLED unset/false to disable entirely —
# the app works exactly the same without it.
BOX_ENABLED="false"
# Destination "Working folder" ID — the number in its Box URL (.../folder/<id>).
BOX_FOLDER_ID=""
# Auth option A — Client Credentials Grant (a service account). Recommended for
# production; acts as the App User when the subject is the enterprise.
BOX_CLIENT_ID=""
BOX_CLIENT_SECRET=""
BOX_SUBJECT_ID=""              # Enterprise ID (or a user ID, with BOX_SUBJECT_TYPE=user)
BOX_SUBJECT_TYPE="enterprise"  # "enterprise" (App User) or "user"
# Auth option B — a short-lived developer token, for quick local testing only
# (expires ~60 min). Takes precedence over CCG when set.
BOX_DEVELOPER_TOKEN=""
